{
  "scout": {
    "auto_scan_pattern": "ch|chapter|prelude",
    "ignore_keywords": ["ooc", "gm", "staff", "test"],
    "forum_is_chapter": true
  },
  "refinery": {
    "truncation_limit": 100,
